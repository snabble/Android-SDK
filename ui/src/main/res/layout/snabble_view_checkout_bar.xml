<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="LinearLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:orientation="vertical"
    tools:background="#ededed">

    <RelativeLayout
        android:id="@+id/cart_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">
        <LinearLayout
            android:id="@+id/discount_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/cart_button_view"
            android:gravity="end"
            android:clipChildren="false"
            android:orientation="vertical">
            <TextView
                android:id="@+id/discount_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="Discount"/>

            <TextView
                android:id="@+id/discount_sum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                tools:text="\?"/>
        </LinearLayout>

        <io.snabble.sdk.ui.scanner.CartButtonView
            android:id="@+id/cart_button_view"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="16dp" />

        <LinearLayout
            android:id="@+id/price_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:layout_toEndOf="@+id/cart_button_view"
            android:clipChildren="false"
            android:orientation="vertical">
            <TextView
                android:id="@+id/article_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="Total" />

            <TextView
                android:id="@+id/price_sum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                tools:text="13,37 €"/>
        </LinearLayout>

    </RelativeLayout>
        <LinearLayout
            android:id="@+id/payment_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:clipChildren="false"
            android:weightSum="2"
            android:orientation="horizontal">
            <FrameLayout android:id="@+id/payment_selector"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="16dp">

                <com.google.android.material.button.MaterialButton
                    style="@style/Snabble.Widget.MaterialComponents.Button.OutlinedButton"
                    android:id="@+id/payment_selector_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="@drawable/snabble_stroke" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_height="48dp"
                    android:importantForAccessibility="no">
                    <ImageView
                        android:id="@+id/payment_icon"
                        android:layout_width="48dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="8dp"
                        android:scaleType="centerInside"
                        tools:src="@drawable/snabble_ic_payment_select_sepa"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/payment_text"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:layout_gravity="center"
                        android:paddingStart="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Bezahle mit SEPA"
                        android:importantForAccessibility="no" />

                    <ImageView
                        android:id="@+id/payment_chevron"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginStart="8dp"
                        android:layout_gravity="center"
                        android:src="@drawable/snabble_ic_small_chevron_down"
                        app:tint="?attr/colorOnSurface"
                        android:importantForAccessibility="no" />
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                style="@style/Snabble.Widget.MaterialComponents.Button"
                android:id="@+id/pay"
                android:layout_width="0px"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetLeft="0dp"
                android:insetBottom="0dp"
                android:layout_weight="1"
                tools:visibility="gone"
                android:text="@string/Snabble.Shoppingcart.buyProducts.now"
                app:strokeColor="@drawable/snabble_stroke" />

            <include android:id="@+id/google_pay_button_layout"
                android:layout_width="0px"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                layout="@layout/snabble_buy_with_googlepay_button_no_shadow"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            style="@style/Snabble.Widget.MaterialComponents.Button.Passive"
            android:id="@+id/payment_selector_button_big"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetLeft="0dp"
            android:insetBottom="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="@string/Snabble.Shoppingcart.buyProducts.selectPaymentMethod" />
</merge>